@model IEnumerable<ASC.Model.ServiceRequest>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row">
    <div class="col s12">
        <h4 class="brown-text">Dashboard</h4>
        <p class="grey-text">Welcome back, <strong>@User.Identity?.Name</strong></p>
    </div>
</div>

<!-- Stats Cards -->
<div class="row">
    <div class="col s12 m3">
        <div class="card brown darken-1">
            <div class="card-content white-text center-align">
                <i class="material-icons large">list</i>
                <h4>@ViewBag.TotalRequests</h4>
                <p>Total Requests</p>
            </div>
        </div>
    </div>
    <div class="col s12 m3">
        <div class="card orange darken-1">
            <div class="card-content white-text center-align">
                <i class="material-icons large">hourglass_empty</i>
                <h4>@ViewBag.PendingRequests</h4>
                <p>Pending</p>
            </div>
        </div>
    </div>
    <div class="col s12 m3">
        <div class="card blue darken-1">
            <div class="card-content white-text center-align">
                <i class="material-icons large">autorenew</i>
                <h4>@ViewBag.InProgressRequests</h4>
                <p>In Progress</p>
            </div>
        </div>
    </div>
    <div class="col s12 m3">
        <div class="card green darken-1">
            <div class="card-content white-text center-align">
                <i class="material-icons large">check_circle</i>
                <h4>@ViewBag.CompletedRequests</h4>
                <p>Completed</p>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row">
    <div class="col s12">
        @if (User.IsInRole("User"))
        {
            <a href="/ServiceRequests/ServiceRequest/ServiceRequest" class="btn brown darken-2 waves-effect">
                <i class="material-icons left">add</i>New Service Request
            </a>
        }
        @if (User.IsInRole("Admin"))
        {
            <a href="/Configuration/MasterData/MasterKeys" class="btn blue darken-1 waves-effect" style="margin-left:8px">
                <i class="material-icons left">settings</i>Master Data
            </a>
            <a href="/Accounts/Account/ServiceEngineers" class="btn teal darken-1 waves-effect" style="margin-left:8px">
                <i class="material-icons left">people</i>Engineers
            </a>
        }
    </div>
</div>

<!-- Recent Requests Table -->
<div class="row" style="margin-top:16px">
    <div class="col s12">
        <div class="card">
            <div class="card-content">
                <span class="card-title brown-text">Recent Service Requests</span>
                @if (Model != null && Model.Any())
                {
                    <table class="striped responsive-table highlight">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Customer</th>
                                <th>Vehicle</th>
                                <th>Services</th>
                                <th>Engineer</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in Model)
                            {
                                <tr>
                                    <td><code>@req.UniqueId?.Substring(0, 8)</code></td>
                                    <td>@req.CustomerEmail</td>
                                    <td>@req.VehicleName<br/><small class="grey-text">@req.VehicleRegistrationNumber</small></td>
                                    <td>@req.RequestedServices</td>
                                    <td>@(req.ServiceEngineer ?? "-")</td>
                                    <td>
                                        <span class="badge @(req.Status == "Completed" ? "green" : req.Status == "InProgress" ? "blue" : req.Status == "Cancelled" ? "red" : "orange") white-text new">
                                            @req.Status
                                        </span>
                                    </td>
                                    <td>@req.RequestedDate?.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <a href="/ServiceRequests/ServiceRequest/Details/@req.UniqueId"
                                           class="btn-small brown waves-effect">
                                            <i class="material-icons">visibility</i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="center-align" style="padding:40px">
                        <i class="material-icons grey-text large">inbox</i>
                        <p class="grey-text">No service requests found.</p>
                        @if (User.IsInRole("User"))
                        {
                            <a href="/ServiceRequests/ServiceRequest/ServiceRequest" class="btn brown darken-2 waves-effect">
                                <i class="material-icons left">add</i>Create First Request
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
