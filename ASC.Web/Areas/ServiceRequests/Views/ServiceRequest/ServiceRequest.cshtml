@model ASC.Model.ServiceRequest
@{
    ViewData["Title"] = "New Service Request";
}

<div class="row">
    <div class="col s12">
        <h4 class="brown-text">New Service Request</h4>
    </div>
</div>

<div class="row">
    <div class="col s12 m8 offset-m2">
        <div class="card">
            <div class="card-content">
                <form asp-action="ServiceRequest" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="red-text"></div>

                    <div class="input-field">
                        <i class="material-icons prefix">directions_car</i>
                        <input asp-for="VehicleName" id="VehicleName" type="text" class="validate" required />
                        <label asp-for="VehicleName">Vehicle Name / Model</label>
                        <span asp-validation-for="VehicleName" class="red-text helper-text"></span>
                    </div>

                    <div class="input-field">
                        <i class="material-icons prefix">confirmation_number</i>
                        <input asp-for="VehicleRegistrationNumber" id="VehicleRegistrationNumber" type="text" class="validate" required />
                        <label asp-for="VehicleRegistrationNumber">Registration Number</label>
                        <span asp-validation-for="VehicleRegistrationNumber" class="red-text helper-text"></span>
                    </div>

                    <div class="input-field">
                        <i class="material-icons prefix">build</i>
                        <input asp-for="RequestedServices" id="RequestedServices" type="text" class="validate" required />
                        <label asp-for="RequestedServices">Services Required (e.g. Engine, Tyres, AC)</label>
                        <span asp-validation-for="RequestedServices" class="red-text helper-text"></span>
                    </div>

                    <div class="input-field">
                        <i class="material-icons prefix">comment</i>
                        <textarea asp-for="Comments" id="Comments" class="materialize-textarea"></textarea>
                        <label asp-for="Comments">Additional Comments</label>
                    </div>

                    <div class="row" style="margin-top:20px">
                        <div class="col s12">
                            <button type="submit" class="btn brown darken-2 waves-effect waves-light">
                                <i class="material-icons left">send</i>Submit Request
                            </button>
                            <a href="/ServiceRequests/Dashboard/Dashboard" class="btn-flat waves-effect" style="margin-left:10px">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
