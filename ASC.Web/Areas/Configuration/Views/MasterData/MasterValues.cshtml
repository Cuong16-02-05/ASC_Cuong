@model IEnumerable<ASC.Model.MasterDataValue>
@{
    ViewData["Title"] = "Master Values";
    var keyId = ViewBag.KeyId as string;
    var keyName = ViewBag.KeyName as string;
}

<div class="row">
    <div class="col s12">
        <a href="/Configuration/MasterData/MasterKeys" class="btn-flat brown-text">
            <i class="material-icons left">arrow_back</i>Back to Master Keys
        </a>
        <h4 class="brown-text">Values for: <em>@keyName</em></h4>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="row"><div class="col s12">
        <div class="card-panel green lighten-4 green-text text-darken-2 auto-dismiss">
            <i class="material-icons tiny">check_circle</i> @TempData["Success"]
        </div>
    </div></div>
}

<!-- Add New Value -->
<div class="row">
    <div class="col s12 m6">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Add New Value</span>
                <form asp-action="CreateMasterValue" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="keyId" value="@keyId" />
                    <input type="hidden" name="keyName" value="@keyName" />
                    <div class="input-field">
                        <i class="material-icons prefix">label</i>
                        <input name="name" type="text" id="valname" class="validate" required />
                        <label for="valname">Value Name</label>
                    </div>
                    <button type="submit" class="btn brown darken-2 waves-effect">
                        <i class="material-icons left">add</i>Add Value
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Values List -->
<div class="row">
    <div class="col s12">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Existing Values</span>
                <table class="striped responsive-table">
                    <thead>
                        <tr><th>Value Name</th><th>Status</th><th>Created</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var val in Model)
                        {
                            <tr>
                                <td>@val.Name</td>
                                <td>
                                    <span class="badge @(val.IsActive ? "green" : "grey") white-text">
                                        @(val.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>@val.CreatedDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <form asp-action="ToggleMasterValue" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@val.UniqueId" />
                                        <input type="hidden" name="name" value="@val.Name" />
                                        <input type="hidden" name="isActive" value="@val.IsActive" />
                                        <input type="hidden" name="keyId" value="@keyId" />
                                        <input type="hidden" name="keyName" value="@keyName" />
                                        <button type="submit" class="btn-small @(val.IsActive ? "orange" : "green") waves-effect">
                                            <i class="material-icons">@(val.IsActive ? "visibility_off" : "visibility")</i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!Model.Any())
                {
                    <p class="center-align grey-text" style="padding:20px">No values defined for this key yet.</p>
                }
            </div>
        </div>
    </div>
</div>
