@model IEnumerable<ASC.Model.MasterDataKey>
@{
    ViewData["Title"] = "Master Keys";
}

<div class="row">
    <div class="col s12"><h4 class="brown-text">Master Data Keys</h4></div>
</div>

@if (TempData["Success"] != null)
{
    <div class="row"><div class="col s12">
        <div class="card-panel green lighten-4 green-text text-darken-2 auto-dismiss">
            <i class="material-icons tiny">check_circle</i> @TempData["Success"]
        </div>
    </div></div>
}
@if (TempData["Error"] != null)
{
    <div class="row"><div class="col s12">
        <div class="card-panel red lighten-4 red-text text-darken-2">
            <i class="material-icons tiny">error</i> @TempData["Error"]
        </div>
    </div></div>
}

<!-- Add New Key -->
<div class="row">
    <div class="col s12 m6">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Add New Master Key</span>
                <form asp-action="CreateMasterKey" method="post">
                    @Html.AntiForgeryToken()
                    <div class="input-field">
                        <i class="material-icons prefix">vpn_key</i>
                        <input name="name" type="text" id="keyname" class="validate" required />
                        <label for="keyname">Key Name (e.g. ServiceType, VehicleBrand)</label>
                    </div>
                    <button type="submit" class="btn brown darken-2 waves-effect">
                        <i class="material-icons left">add</i>Add Key
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Keys List -->
<div class="row">
    <div class="col s12">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Existing Master Keys</span>
                <table class="striped responsive-table">
                    <thead>
                        <tr>
                            <th>Key Name</th>
                            <th>Status</th>
                            <th>Created By</th>
                            <th>Created Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var key in Model)
                        {
                            <tr>
                                <td>
                                    <a href="/Configuration/MasterData/MasterValues?keyId=@key.UniqueId&keyName=@key.Name" class="brown-text">
                                        <strong>@key.Name</strong>
                                    </a>
                                </td>
                                <td>
                                    <span class="badge @(key.IsActive ? "green" : "grey") white-text">
                                        @(key.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>@key.CreatedBy</td>
                                <td>@key.CreatedDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <a href="/Configuration/MasterData/MasterValues?keyId=@key.UniqueId&keyName=@key.Name"
                                       class="btn-small blue waves-effect" title="View Values">
                                        <i class="material-icons">list</i>
                                    </a>
                                    <form asp-action="ToggleMasterKey" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@key.UniqueId" />
                                        <input type="hidden" name="name" value="@key.Name" />
                                        <input type="hidden" name="isActive" value="@key.IsActive" />
                                        <button type="submit" class="btn-small @(key.IsActive ? "orange" : "green") waves-effect" title="Toggle">
                                            <i class="material-icons">@(key.IsActive ? "visibility_off" : "visibility")</i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!Model.Any())
                {
                    <p class="center-align grey-text" style="padding:20px">No master keys defined yet.</p>
                }
            </div>
        </div>
    </div>
</div>
