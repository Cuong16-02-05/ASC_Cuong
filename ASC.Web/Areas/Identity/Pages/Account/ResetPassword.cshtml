@page
@model ASC.Web.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
}

<div class="row" style="min-height:100vh; background:linear-gradient(135deg,#4e342e,#795548); display:flex; align-items:center; margin:0">
    <div class="col s12 m6 l4" style="margin:0 auto">
        <div class="card" style="border-radius:12px">
            <div class="card-content brown darken-2 white-text center-align" style="padding:25px">
                <i class="material-icons" style="font-size:50px">lock_reset</i>
                <h5>Reset Password</h5>
            </div>
            <div class="card-content" style="padding:25px">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="red-text"></div>
                    <input asp-for="Input.Code" type="hidden" />
                    <div class="input-field">
                        <i class="material-icons prefix">email</i>
                        <input asp-for="Input.Email" type="email" id="email" class="validate" />
                        <label for="email">Email</label>
                        <span asp-validation-for="Input.Email" class="helper-text red-text"></span>
                    </div>
                    <div class="input-field">
                        <i class="material-icons prefix">lock</i>
                        <input asp-for="Input.Password" type="password" id="pwd" class="validate" />
                        <label for="pwd">New Password</label>
                        <span asp-validation-for="Input.Password" class="helper-text red-text"></span>
                    </div>
                    <div class="input-field">
                        <i class="material-icons prefix">lock_outline</i>
                        <input asp-for="Input.ConfirmPassword" type="password" id="cpwd" class="validate" />
                        <label for="cpwd">Confirm New Password</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="helper-text red-text"></span>
                    </div>
                    <button type="submit" class="btn brown darken-2 waves-effect" style="width:100%; margin-top:10px">
                        <i class="material-icons left">save</i>Reset Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
