@page
@{
    ViewData["Title"] = "Reset Password Confirmation";
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
}

<div class="row" style="min-height:100vh; background:linear-gradient(135deg,#4e342e,#795548); display:flex; align-items:center; margin:0">
    <div class="col s12 m6 l4" style="margin:0 auto">
        <div class="card" style="border-radius:12px">
            <div class="card-content center-align" style="padding:40px">
                <i class="material-icons green-text" style="font-size:70px">check_circle</i>
                <h5>Reset Successful!</h5>
                <p class="grey-text">Your password has been reset successfully.</p>
                <a asp-page="./Login" class="btn brown darken-2 waves-effect" style="margin-top:20px">
                    <i class="material-icons left">login</i>Click here to log in
                </a>
            </div>
        </div>
    </div>
</div>