@page
@{
    ViewData["Title"] = "Forgot Password Confirmation";
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
}

<div class="row" style="min-height:100vh; background:linear-gradient(135deg,#4e342e,#795548); display:flex; align-items:center; margin:0">
    <div class="col s12 m6 l4" style="margin:0 auto">
        <div class="card" style="border-radius:12px">
            <div class="card-content center-align" style="padding:40px">
                <i class="material-icons green-text" style="font-size:70px">mark_email_read</i>
                <h5>Check Your Email</h5>
                <p class="grey-text">A password reset link has been sent to your email address. Please check your inbox.</p>
                <a asp-page="./Login" class="btn brown darken-2 waves-effect" style="margin-top:10px">
                    <i class="material-icons left">login</i>Back to Login
                </a>
            </div>
        </div>
    </div>
</div>