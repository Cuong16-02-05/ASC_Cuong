@page
@model ASC.Web.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
}

<div class="row" style="min-height:100vh; background:linear-gradient(135deg,#4e342e,#795548); display:flex; align-items:center; margin:0">
    <div class="col s12 m6 l4" style="margin:0 auto">
        <div class="card" style="border-radius:12px">
            <div class="card-content brown darken-2 white-text center-align" style="padding:25px">
                <i class="material-icons" style="font-size:50px">lock_open</i>
                <h5>Forgot Password?</h5>
            </div>
            <div class="card-content" style="padding:25px">
                <p class="grey-text">Enter your email and we'll send you a reset link.</p>
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="red-text"></div>
                    <div class="input-field">
                        <i class="material-icons prefix">email</i>
                        <input asp-for="Input.Email" type="email" id="email" class="validate" />
                        <label for="email">Email Address</label>
                        <span asp-validation-for="Input.Email" class="helper-text red-text"></span>
                    </div>
                    <button type="submit" class="btn brown darken-2 waves-effect" style="width:100%; margin-top:10px">
                        <i class="material-icons left">send</i>Send Reset Link
                    </button>
                </form>
                <div class="center-align" style="margin-top:15px">
                    <a asp-page="./Login" class="brown-text">Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
