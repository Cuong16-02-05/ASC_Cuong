@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}
@inject Microsoft.Extensions.Options.IOptions<ASC.Web.Configuration.ApplicationSettings> Settings

<!-- Hero -->
<div style="background:linear-gradient(135deg,#4e342e,#795548);padding:80px 0;text-align:center">
    <div class="container">
        <h2 class="white-text">@Settings.Value.Title</h2>
        <p class="white-text" style="opacity:.8;font-size:18px">Professional Car Maintenance &amp; Repair Services</p>
        <a href="/Identity/Account/Login" class="btn-large waves-effect waves-light white brown-text" style="margin-top:20px">
            <i class="material-icons left">directions_car</i>Get Started
        </a>
    </div>
</div>

<!-- 3-column section (Lab 1 exact content) -->
<div class="container">
    <div class="section">
        <div class="row">
            <div class="col s12 m4">
                <div class="icon-block center-align">
                    <h2 class="center brown-text"><i class="material-icons large">group</i></h2>
                    <h5 class="center">Who we are</h5>
                    <p class="light">We believe in providing seamless and high-quality services to our customers. Our customer-first approach will offer a unique personalized experience that will bring more value to your car through a smarter and quicker process. We are committed to great quality.</p>
                </div>
            </div>
            <div class="col s12 m4">
                <div class="icon-block center-align">
                    <h2 class="center brown-text"><i class="material-icons large">flash_on</i></h2>
                    <h5 class="center">Our Competency</h5>
                    <p class="light">By utilizing the elements and principles of modern mechanical engineering, we are able to resolve complex technical challenges through innovative solutions. Additionally, our service engineers are highly qualified, with advanced training in automobile engineering.</p>
                </div>
            </div>
            <div class="col s12 m4">
                <div class="icon-block center-align">
                    <h2 class="center brown-text"><i class="material-icons large">settings</i></h2>
                    <h5 class="center">Easy to work with</h5>
                    <p class="light">We provide detailed information and predictive analysis to help our customers understand their cars. We maintain continuous communication and are always open to feedback. We are always available to answer our customers' inquiries.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Parallax banner 1 -->
<div class="brown darken-1" style="padding:40px 0;text-align:center">
    <h5 class="white-text">Commited to delivering unprecedented quality to our customers</h5>
</div>

<!-- Customer Value -->
<div class="container">
    <div class="section">
        <div class="row">
            <div class="col s12 center">
                <h4>Customer Value</h4>
                <p class="left-align light">Automobile Service Center has always been a value-driven company. Many of our values are based on years of research and commitment. Our values reflect the manner in which we run our business. We're proud of our professional ethics in dealing with our business partners, investors, employees, and customers. We provide customer-valued services built on our commitment to responsibility, sustainability, trust, openness, diversity, reliability, determination, credibility, and initiation.</p>
            </div>
        </div>
    </div>
</div>

<!-- Parallax banner 2 -->
<div class="brown darken-2" style="padding:40px 0;text-align:center">
    <h5 class="white-text">Humility, Empathy, Hard Work, and Technology are our core drivers.</h5>
</div>
